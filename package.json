    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.107.0",
    "@electric-sql/pglite": "^0.5.1",
    "@tailwindcss/typography": "^0.5.20",
    "drizzle-orm": "^0.45.2",
    "next": "^16.2.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
