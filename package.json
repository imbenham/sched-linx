{
  "name": "sched-linx",
  "version": "0.0.0",
  "private": true,
  "description": "DLX-based scheduling prototype. TypeScript + ESM. Algorithm-first.",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build:refdb": "tsx scripts/build-ref-db.ts",
