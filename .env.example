# Template committed to git. Real values live in .env.local (gitignored).
# Copy this to .env.local and fill in.

# ─── Anthropic Claude (agentic onboarding) ──────────────────────────────────
# Used by the agentic-onboarding route to drive Claude-based scenario
# generation. Default to Sonnet for cost + iteration speed; bump to
# claude-opus-4-8 if you want richer reasoning at higher cost.
#
# Safe to leave unset on a read-only deploy (NEXT_PUBLIC_AGENTIC_READONLY=1).
# The client is lazy-initialized only when sendUserMessage runs, which is
# blocked before it gets there in read-only mode. Read paths (list, view,
# replay, export) never touch the API.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── Deploy behavior ─────────────────────────────────────────────────────────
# Set to "1" on the public deploy to disable createSetup, sendUserMessage,
# updateSetupTitle, and commitSetup. Visitors can still view and replay
# any pre-seeded transcripts under .data/*.json (see the ReadOnlyBanner
# on the agentic-onboarding pages). Leave blank locally + on your own
# fork so the live agentic flow works end-to-end.
NEXT_PUBLIC_AGENTIC_READONLY=

# URL surfaced by the ReadOnlyBanner as the "Fork on GitHub" target.
# Falls back to the canonical repo URL in src/env.ts if unset; override
# for a fork or a staging preview.
NEXT_PUBLIC_GITHUB_URL=
